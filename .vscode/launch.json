{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Servidor + Frontend (Dev)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "dev"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "Solo Servidor (Backend)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/server/index.js",
            "cwd": "${workspaceFolder}/server",
            "console": "integratedTerminal",
            "restart": true,
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "Electron App",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
            "args": ["${workspaceFolder}/electron-main.js"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "Publicar Release",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/publicar.ps1"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}