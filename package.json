{
  "name": "sacware-kiosco",
  "version": "2.0.0",
  "description": "Sistema de Gestión Comercial para Kioscos",
  "private": true,
  "main": "electron-main.js",
  "author": "SAC Web Agency",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite\"",
    "server": "nodemon --watch server server/index.js",
    "build": "vite build",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "version:show": "node -e \"console.log('v' + require('./package.json').version)\"",
    "dist": "npm run build && electron-builder",
    "dist:publish": "npm run build && electron-builder --publish always",
    "dist:win": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-packager . SACWare-Kiosco --platform=win32 --arch=x64 --out=dist_electron --overwrite --asar --extra-resource=server",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps",
    "electron:build": "vite build && electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fabriimagnelli/kiosco-app.git"
  },
  "build": {
    "appId": "com.sacwebagency.kiosco",
    "productName": "SACWare Kiosco",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "electron-main.js",
      "preload.js",
      "package.json",
      "server/**/*",
      "!server/node_modules/**",
      "!server/package.json",
      "!server/package-lock.json",
      "!server/kiosco.sqbpro",
      "!server/*.db",
      "!server/*.db.sql"
    ],
    "asarUnpack": [
      "node_modules/sqlite3/**",
      "node_modules/sharp/**",
      "preload.js"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "fabriimagnelli",
        "repo": "kiosco-app"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "SACWare Kiosco"
    }
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "qrcode.react": "^4.2.0",
    "sharp": "^0.34.5",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "24.8.8",
    "electron-builder": "^26.7.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.562.0",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0",
    "xlsx": "^0.18.5"
  }
}
